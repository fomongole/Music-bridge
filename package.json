{
  "name": "music-bridge",
  "version": "1.0.0",
  "description": "Bridge your Android music library to your desktop.",
  "main": "electron/main.js",
  "scripts": {
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "desktop": "electron electron/main.js",
    "build:server": "pnpm --filter server build",
    "build:client": "pnpm --filter client build",
    "dist": "pnpm run build:server && pnpm run build:client && electron-builder"
  },
  "build": {
    "appId": "com.engineerfred.musicbridge",
    "productName": "MusicBridge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "packages/client/dist/**/*",
      "packages/server/dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["usb", "electron", "electron-winstaller"]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}